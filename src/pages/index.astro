---
import '../styles/global.css'
import CategorySection from '../components/CategorySection.astro'
import yugiohCategories from '../data/yugioh/category.json'
import yugiohDecks from '../data/yugioh/decks.json'
import gundamCategories from '../data/gundam/category.json'
import gundamDecks from '../data/gundam/decks.json'
import riftboundCategories from '../data/riftbound/category.json'
import riftboundDecks from '../data/riftbound/decks.json'
import Stepper from '../components/Stepper.astro'
import Header from '../components/Header.astro'
import { pwaInfo } from 'virtual:pwa-info'

interface Category {
  id: string
  title: string
  image: string
  banlist: string
  cardPool: string
}

interface Deck {
  title: string
  imageUrl: string
  linkUrl: string
  finished: boolean
  colors: string[]
}

interface GameCatalogue {
  id: 'yugioh' | 'gundam' | 'riftbound'
  label: string
  categories: Category[]
  decks: Record<string, Deck[]>
}

const games: GameCatalogue[] = [
  {
    id: 'yugioh',
    label: 'Yugioh',
    categories: yugiohCategories,
    decks: yugiohDecks,
  },
  {
    id: 'gundam',
    label: 'Gundam',
    categories: gundamCategories,
    decks: gundamDecks,
  },
  {
    id: 'riftbound',
    label: 'Riftbound',
    categories: riftboundCategories,
    decks: riftboundDecks,
  },
]
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.ico" type="image/x-icon" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="mask-icon" href="/favicon.svg" color="#FFFFFF" />
    <meta name="msapplication-TileColor" content="#16a34a" />
    <meta name="theme-color" content="#16a34a" />
    <title>Michael's Decks</title>
    <meta name="description" content="Michael's Decks" />
    <script src="/src/pwa.ts"></script>
    {pwaInfo && <Fragment set:html={pwaInfo.webManifest.linkTag} />}
    <script is:inline>
      document.addEventListener('alpine:init', () => {
        Alpine.data('gameCatalogue', () => ({
          currentGame: 'yugioh',
          games: ['yugioh', 'gundam', 'riftbound'],
          init() {
            const savedGame = window.localStorage.getItem('currentGame')
            if (this.games.includes(savedGame)) {
              this.currentGame = savedGame
            }

            this.$watch('currentGame', (gameId) => {
              window.localStorage.setItem('currentGame', gameId)
            })
          },
          setGame(gameId) {
            if (this.games.includes(gameId)) {
              this.currentGame = gameId
            }
          },
        }))
      })
    </script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
  </head>
  <body class="bg-background text-text" x-data="gameCatalogue()" x-init="init()" :data-game="currentGame">
    <Header />
    {
      games.map((game) => (
        <Fragment>
          <Stepper gameId={game.id} categories={game.categories} />
          <main x-show={`currentGame === '${game.id}'`} x-cloak class="container mx-auto py-8 px-4">
            {game.categories.map((category) => {
              const categoryDecks = game.decks[category.id] ?? []

              return (
                <CategorySection
                  id={`${game.id}-${category.id}`}
                  gameId={game.id}
                  title={category.title}
                  image={category.image}
                  decks={categoryDecks}
                  isCollapsed={categoryDecks.length === 0}
                  banlist={category.banlist}
                  cardPool={category.cardPool}
                />
              )
            })}
          </main>
        </Fragment>
      ))
    }
  </body>
</html>
