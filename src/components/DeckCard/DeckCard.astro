---
import DeckCardImage from './DeckCardImage.astro'
import { deckColors, type DeckColor } from '../../data/colors'

interface Props {
  gameId: string
  title: string
  imageUrl: string
  linkUrl: string
  finished: boolean
  colors?: string[]
}

const { gameId, title, imageUrl, linkUrl, finished, colors = [] } = Astro.props
const imagePath = `/images/decks/${gameId}/${imageUrl}`
const colorValues = colors.flatMap((color) => {
  const colorValue = deckColors[color as DeckColor]

  return colorValue ? [colorValue] : []
})
const hasColors = colorValues.length > 0
---

<a href={linkUrl} class="group transition-all duration-300" target="_blank">
  <div
    class="overflow-hidden rounded-lg border-2 border-surface group-hover:border-primary transition-all duration-300"
  >
    <DeckCardImage src={imagePath} alt={title} width={230} height={230} finished={finished} />
  </div>
  <div
    class:list={[
      'mt-2 flex items-center text-lg text-text transition-colors duration-300 group-hover:text-primary',
      hasColors ? 'justify-between gap-2' : 'justify-center text-center',
    ]}
  >
    {
      hasColors && (
        <div class="flex items-center gap-1.5" aria-label={`${title} colors`}>
          {colorValues.map((color) => (
            <span
              class="h-3 w-3 rounded-full border border-black/20"
              style={`background-color: ${color}`}
              aria-hidden="true"
            />
          ))}
        </div>
      )
    }
    <p class:list={[hasColors ? 'text-right' : 'text-center']}>{title}</p>
  </div>
</a>
